{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "g++ active file",
            "command": "/usr/bin/g++",
            "args": [
                "-g",
                "${file}",
                "-pthread",
                "-o",
                "${workspaceRoot}/build/${fileBasenameNoExtension}",
                "-I",
                "${workspaceRoot}/src/header"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "isBackground": false
        }
    ],
    "version": "2.0.0"
}